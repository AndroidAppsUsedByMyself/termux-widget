<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".activities.WidgetColorSettingsActivity">

    <include
        layout="@layout/partial_primary_toolbar"
        android:id="@+id/partial_primary_toolbar"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent" >
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/activity_vertical_margin"
            android:paddingBottom="@dimen/activity_vertical_margin"
            android:paddingLeft="@dimen/activity_horizontal_margin"
            android:paddingRight="@dimen/activity_horizontal_margin">

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_custom_colors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_custom_colors"
                android:textSize="16sp"
                android:paddingBottom="16dp"/>

            <View
                style="@style/ViewDivider"/>

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_widget_colors"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:textColor="?android:textColorPrimary"/>

            <LinearLayout
                android:id="@+id/custom_colors_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_header_background"
                        android:textSize="14sp"/>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/text_header_background"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:paddingEnd="8dp"
                        android:textColor="?android:textColorSecondary"/>

                    <View
                        android:id="@+id/view_header_background"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@android:color/white"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_header_text"
                        android:textSize="14sp"/>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/text_header_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:paddingEnd="8dp"
                        android:textColor="?android:textColorSecondary"/>

                    <View
                        android:id="@+id/view_header_text"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@android:color/black"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_list_background"
                        android:textSize="14sp"/>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/text_list_background"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:paddingEnd="8dp"
                        android:textColor="?android:textColorSecondary"/>

                    <View
                        android:id="@+id/view_list_background"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@android:color/white"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_divider"
                        android:textSize="14sp"/>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/text_divider"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:paddingEnd="8dp"
                        android:textColor="?android:textColorSecondary"/>

                    <View
                        android:id="@+id/view_divider"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@android:color/darker_gray"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_empty_view_background"
                        android:textSize="14sp"/>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/text_empty_background"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:paddingEnd="8dp"
                        android:textColor="?android:textColorSecondary"/>

                    <View
                        android:id="@+id/view_empty_background"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@android:color/white"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_empty_view_text"
                        android:textSize="14sp"/>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/text_empty_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:paddingEnd="8dp"
                        android:textColor="?android:textColorSecondary"/>

                    <View
                        android:id="@+id/view_empty_text"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@android:color/black"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_item_text"
                        android:textSize="14sp"/>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/text_item_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:paddingEnd="8dp"
                        android:textColor="?android:textColorSecondary"/>

                    <View
                        android:id="@+id/view_item_text"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@android:color/black"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_reset_colors"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/settings_reset_colors"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
